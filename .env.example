# Docker Compose secrets template. Copy to .env (git-ignored) and fill in real values.

# Dev HTTPS cert password (see certs/ — generate with dotnet dev-certs https).
# Create folder certs\  in root folder
# Run dotnet dev-certs https -ep .\certs\orangepuffportal-devcert.pfx -p "dev_cert_password"
# See docker-compose.yml:10
DEV_CERT_PASSWORD=

# Google Cloud Console -> Clients -> a dev OAuth client for this sample host.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bootstrap admin password, used only the first time DoMigration seeds an empty Users table.
# Wired into docker-compose.yml as Seed__AdminPassword — used when running via `docker compose up`.
# Running outside Docker with `dotnet run` instead? Use User Secrets so it never touches
# appsettings.json:
#   dotnet user-secrets set "Seed:AdminPassword" "02210221" --project samples/OrangepuffPortal.SampleHost
SEED_ADMIN_PASSWORD=
